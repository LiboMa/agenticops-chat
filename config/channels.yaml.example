# Notification Channels — sole source of truth for channel configuration.
# Copy this file to channels.yaml and fill in your values.
# Env var interpolation: ${VAR_NAME}
#
# Each channel has:
#   type:             Channel type (feishu, dingtalk, wecom, slack, email, sns, sns-report, webhook)
#   enabled:          true/false (default: true)
#   severity_filter:  List of severities to notify for (empty = all)
#   preferred_format: Format for report distribution (markdown, html, text, pdf).
#                     Defaults per type: feishu/dingtalk/wecom/slack/webhook=markdown, email/sns-report=html, sns=text
#   ...               All other keys become the notifier config dict

channels:
  # Feishu (Lark) example
  my-feishu-alerts:
    type: feishu
    enabled: true
    preferred_format: markdown
    app_name: default
    chat_id: "${FEISHU_CHAT_ID}"

  # Slack example
  my-slack-alerts:
    type: slack
    enabled: true
    preferred_format: markdown
    severity_filter: ["critical", "high"]
    webhook_url: "${SLACK_WEBHOOK_URL}"
    channel: "#alerts"

  # Email example
  ops-email:
    type: email
    enabled: false
    preferred_format: html
    smtp_host: "${SMTP_HOST}"
    smtp_port: 587
    smtp_user: "${SMTP_USER}"
    smtp_password: "${SMTP_PASSWORD}"
    from_email: "aiops@example.com"
    to_emails: ["ops@example.com"]

  # Webhook example
  my-webhook:
    type: webhook
    enabled: false
    preferred_format: markdown
    url: "${WEBHOOK_URL}"
    method: POST

  # SNS Report Distribution — sends formatted reports to email subscribers
  ops-reports:
    type: sns-report
    enabled: false
    preferred_format: html
    topic_arn: "${SNS_REPORT_TOPIC_ARN}"
    region: "us-east-1"
    s3_bucket: "${REPORT_S3_BUCKET}"
    s3_prefix: "reports/"
    s3_region: "us-east-1"          # defaults to region if omitted
    url_expiry: 604800              # presigned URL expiry (seconds), default 7 days
    formats: [html, pdf, markdown]  # which formats to generate
    report_types: [daily, incident] # auto-distribute only these types (empty = all)
    # SES HTML email delivery (optional) — renders HTML in email clients.
    # Without SES, SNS email sends plain text only (no HTML rendering).
    # Both sender and recipients must be verified in SES (sandbox mode).
    ses_sender: "${SES_SENDER_EMAIL}"          # verified SES sender email
    ses_recipients: ["${SES_RECIPIENT_EMAIL}"] # verified SES recipient email(s)
