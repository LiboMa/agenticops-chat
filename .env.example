# AgenticAIOps Configuration
# Copy this file to .env and configure your settings

# Database (SQLite by default)
AIOPS_DATABASE_URL=sqlite:///data/agenticops.db

# AWS Bedrock Configuration
AIOPS_BEDROCK_REGION=us-east-1
AIOPS_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Monitoring Settings
AIOPS_DEFAULT_METRICS_PERIOD=300
AIOPS_ANOMALY_DETECTION_WINDOW=3600

# Executor (Fix Plan Execution)
AIOPS_EXECUTOR_ENABLED=false

# Directories
AIOPS_DATA_DIR=data
AIOPS_REPORTS_DIR=data/reports
AIOPS_KNOWLEDGE_BASE_DIR=data/knowledge_base
